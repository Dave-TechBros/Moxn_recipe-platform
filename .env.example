# Copy to .env.local for local dev, or set these in Vercel (Environment Variables).

# --- Database (REQUIRED) ---
# Local docker:
DATABASE_URL=postgresql://moxn:moxn_dev_pw@localhost:5432/moxn
# On Vercel: set DATABASE_URL = the value of POSTGRES_URL from Storage
# (paste WITHOUT surrounding quotes; add ?sslmode=require for serverless).

# --- Auth (REQUIRED) ---
# Any long random string. Used to sign session JWT cookies.
AUTH_SECRET=generate-a-long-random-string-here

# --- Public site URL (optional) ---
# Used in password-reset emails. Defaults to localhost if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Blob storage for uploads (optional, prod only) ---
# From Vercel Storage -> Blob. Without it, uploads fall back to local disk
# (ephemeral on Vercel). Set this so avatar/recipe images persist.
BLOB_READ_WRITE_TOKEN=
